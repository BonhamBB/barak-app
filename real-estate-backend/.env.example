# Database
# (configure in database.ts or use env)

# OpenAI (for SalesGPT)
OPENAI_API_KEY=sk-...

# Frontend URL (for dashboard links)
FRONTEND_URL=http://localhost:3000

# Email (Nodemailer / SMTP) - required for Magic Onboard & Tour Summary
# Copy this file to .env and fill in your values
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Barak <your-email@gmail.com>

# Optional: set to "true" for port 465 (SSL)
# SMTP_SECURE=false

# For Gmail: use App Password (not regular password)
# https://support.google.com/accounts/answer/185833
